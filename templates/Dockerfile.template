FROM linuxserver/vscodium-web:latest                                                                                                                                                                                        
                                                                                                               
# 1. Install system dependencies (as root)
# Added openssh-server so we can configure sshd_config
RUN apt-get update && apt-get install -y \                                                                  
    curl git wget zsh vim tmux jq build-essential \
    python3 python3-pip python3.12-venv golang-go fontconfig sudo locales openssh-server \
    && rm -rf /var/lib/apt/lists/*                                                                                                                                                                                          
                                                                                                                                                                                                                               
# Generate and set locales (Essential for Powerlevel10k, Zsh encoding, and Tmux)
RUN locale-gen en_US.UTF-8                                                                                                                                                                                                  
ENV LANG=en_US.UTF-8                                                                                                                                                                                                        
ENV LC_ALL=en_US.UTF-8                                                                                                                                                                                                      
                                                                                                                                                                                                                               
# 2. Install Fonts
RUN mkdir -p /usr/share/fonts/truetype/meslo && \
    wget -q -P /usr/share/fonts/truetype/meslo https://github.com/romkatv/dotfiles-public/raw/master/.local/share/fonts/NerdFonts/MesloLGS%20NF%20Regular.ttf && \
    fc-cache -fv

# 3. Install gcloud SDK (Global location)
RUN mkdir -p /opt/google-cloud-sdk && \
    curl -O https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-x86_64.tar.gz && \
    tar -xf google-cloud-cli-linux-x86_64.tar.gz -C /opt && \
    rm google-cloud-cli-linux-x86_64.tar.gz && \
    /opt/google-cloud-sdk/install.sh --quiet

# 4. Global Tool Locations & Environment
ENV NVM_DIR=/opt/nvm
ENV OH_MY_ZSH=/opt/oh-my-zsh
ENV ZSH_CUSTOM=/opt/oh-my-zsh-custom
ENV ZSH_DISABLE_COMPFIX=true
# Pre-set PATH for build layers to find gcloud
ENV PATH=/opt/google-cloud-sdk/bin:$PATH
ENV CLAUDE_CODE_USE_VERTEX=1

# 5. Install NVM, Node, npm, Gemini CLI, Oh My Zsh, and P10k
RUN mkdir -p $NVM_DIR $OH_MY_ZSH $ZSH_CUSTOM && \
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash && \
    bash -c "source $NVM_DIR/nvm.sh && \
             nvm install 20 && \
             nvm alias default 20 && \
             npm install -g @google/gemini-cli" && \
    curl -fsSL https://claude.ai/install.sh | bash && \
    mv /root/.local/bin/claude /usr/local/bin/claude && \
    git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git $OH_MY_ZSH && \
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git $ZSH_CUSTOM/themes/powerlevel10k

# 6. Global Symlinks (Ensures tools are found regardless of shell login type)
RUN ln -s $(bash -c "source $NVM_DIR/nvm.sh && which node") /usr/local/bin/node && \
    ln -s $(bash -c "source $NVM_DIR/nvm.sh && which npm") /usr/local/bin/npm && \
    ln -s $(bash -c "source $NVM_DIR/nvm.sh && which gemini") /usr/local/bin/gemini

# 7. Download a lean default Powerlevel10k config
RUN wget -q -O /etc/skel/.p10k.zsh https://raw.githubusercontent.com/romkatv/powerlevel10k/master/config/p10k-lean.zsh

# 8. Create Global ZSH and Tmux Configurations (PVC Proof)
RUN mkdir -p /etc/zsh && \
    echo 'unsetopt WARN_CREATE_GLOBAL' > /etc/zsh/zshrc && \
    echo '[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh' >> /etc/zsh/zshrc && \
    echo 'export LANG=en_US.UTF-8' >> /etc/zsh/zshrc && \
    echo 'export LC_ALL=en_US.UTF-8' >> /etc/zsh/zshrc && \
    echo 'export ZSH_DISABLE_COMPFIX="true"' >> /etc/zsh/zshrc && \
    echo 'zsh-newuser-install() { :; }' >> /etc/zsh/zshrc && \
    echo '[ -f /etc/zsh/zshrc.gcp ] && source /etc/zsh/zshrc.gcp' >> /etc/zsh/zshrc && \
    echo 'export PATH=$PATH:/opt/google-cloud-sdk/bin' >> /etc/zsh/zshrc && \
    echo '[[ -z "$TMUX" ]] && export TERM=xterm-256color' >> /etc/zsh/zshrc && \
    echo 'export ZSH="/opt/oh-my-zsh"' >> /etc/zsh/zshrc && \
    echo 'export ZSH_CUSTOM="/opt/oh-my-zsh-custom"' >> /etc/zsh/zshrc && \
    echo 'ZSH_THEME="powerlevel10k/powerlevel10k"' >> /etc/zsh/zshrc && \
    echo 'source $ZSH/oh-my-zsh.sh' >> /etc/zsh/zshrc && \
    echo 'export NVM_DIR="/opt/nvm"' >> /etc/zsh/zshrc && \
    echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"' >> /etc/zsh/zshrc && \
    echo 'export CLAUDE_CODE_USE_VERTEX=1' >> /etc/zsh/zshrc

# Global Tmux Config
RUN echo 'set -g prefix C-a' > /etc/tmux.conf && \
    echo 'unbind C-b' >> /etc/tmux.conf && \
    echo 'bind C-a send-prefix' >> /etc/tmux.conf && \
    echo 'set -g default-terminal "tmux-256color"' >> /etc/tmux.conf && \
    echo 'set -ga terminal-overrides ",*256col*:Tc"' >> /etc/tmux.conf && \
    echo 'set -g default-shell /bin/zsh' >> /etc/tmux.conf

# 9. Configure SSHD to Accept Env and Force abc User
RUN mkdir -p /run/sshd /etc/ssh && \
    sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config && \
    echo "AcceptEnv LANG LC_*" >> /etc/ssh/sshd_config && \
    echo "AllowUsers abc" >> /etc/ssh/sshd_config

# 10. Finalize User Setup
RUN usermod -d /home/workspace -m abc && \
    usermod --shell /bin/zsh abc && \
    usermod --shell /bin/zsh root && \
    chown -R abc:abc /opt/nvm /opt/oh-my-zsh /opt/oh-my-zsh-custom && \
    chmod -R g-w,o-w /usr/share/zsh /usr/local/share/zsh 2>/dev/null || true

# 11. Runtime Initialization Script (runs on every container start via S6)
# Fixes ownership after PVC mount, propagates GCP env vars, activates gcloud
RUN mkdir -p /custom-cont-init.d && \
    echo '#!/bin/bash' > /custom-cont-init.d/99-setup-user && \
    echo 'chown abc:abc /home/workspace' >> /custom-cont-init.d/99-setup-user && \
    echo 'mkdir -p /home/workspace/.cache/oh-my-zsh /home/workspace/.cache/p10k-abc' >> /custom-cont-init.d/99-setup-user && \
    echo 'chown -R abc:abc /home/workspace/.cache' >> /custom-cont-init.d/99-setup-user && \
    echo 'touch /home/workspace/.zsh_history /home/workspace/.zshrc' >> /custom-cont-init.d/99-setup-user && \
    echo 'chown abc:abc /home/workspace/.zsh_history /home/workspace/.zshrc' >> /custom-cont-init.d/99-setup-user && \
    echo '[[ ! -f /home/workspace/.p10k.zsh ]] && cp /etc/skel/.p10k.zsh /home/workspace/.p10k.zsh' >> /custom-cont-init.d/99-setup-user && \
    echo 'chown abc:abc /home/workspace/.p10k.zsh' >> /custom-cont-init.d/99-setup-user && \
    echo '# Replace default Debian .zshrc (has bare compinit that causes insecure dir warnings)' >> /custom-cont-init.d/99-setup-user && \
    echo 'if grep -q "prompt adam1" /home/workspace/.zshrc 2>/dev/null; then echo "# User customizations go here" > /home/workspace/.zshrc; fi' >> /custom-cont-init.d/99-setup-user && \
    echo '# Propagate GCP env vars into shell sessions' >> /custom-cont-init.d/99-setup-user && \
    echo 'echo "export GOOGLE_CLOUD_PROJECT=$GOOGLE_CLOUD_PROJECT" > /etc/zsh/zshrc.gcp' >> /custom-cont-init.d/99-setup-user && \
    echo 'echo "export GOOGLE_APPLICATION_CREDENTIALS=$GOOGLE_APPLICATION_CREDENTIALS" >> /etc/zsh/zshrc.gcp' >> /custom-cont-init.d/99-setup-user && \
    echo '# Activate gcloud with mounted service account credentials' >> /custom-cont-init.d/99-setup-user && \
    echo 'if [ -f "$GOOGLE_APPLICATION_CREDENTIALS" ]; then' >> /custom-cont-init.d/99-setup-user && \
    echo '  su -s /bin/bash abc -c "/opt/google-cloud-sdk/bin/gcloud auth activate-service-account --key-file=$GOOGLE_APPLICATION_CREDENTIALS --quiet" || true' >> /custom-cont-init.d/99-setup-user && \
    echo 'fi' >> /custom-cont-init.d/99-setup-user && \
    echo '# Fix ownership of zsh/nvm dirs (build-time UID differs from runtime UID)' >> /custom-cont-init.d/99-setup-user && \
    echo 'chown -R abc:abc /opt/oh-my-zsh /opt/oh-my-zsh-custom /opt/nvm' >> /custom-cont-init.d/99-setup-user && \
    echo 'chmod -R g-w,o-w /opt/oh-my-zsh /opt/oh-my-zsh-custom' >> /custom-cont-init.d/99-setup-user && \
    echo 'chmod g-w,o-w /home/workspace' >> /custom-cont-init.d/99-setup-user && \
    chmod +x /custom-cont-init.d/99-setup-user

# Crucial: Must be root for S6 init to start. 
USER root
ENV HOME=/home/workspace
WORKDIR /home/workspace